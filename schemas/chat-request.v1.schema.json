              ]
            },
            "image_url": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "image_url"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "data",
            "format",
            "type"
          ],
          "properties": {
            "data": {
              "type": "string"
            },
            "format": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "input_audio"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "file_data": {
              "type": [
                "string",
                "null"
              ]
            },
            "file_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "filename": {
              "type": [
                "string",
                "null"
              ]
            },
            "type": {
              "type": "string",
              "enum": [
                "file"
              ]
            }
          }
        }
      ]
    },
    "MessageContent": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ContentPart"
          }
        }
      ]
    },
    "RequestMetadataV1": {
      "type": "object",
      "properties": {
        "group_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "route": {
          "type": [
            "string",
            "null"
          ]
        },
        "session_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "subject_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "virtual_key_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ToolCallV1": {
      "type": "object",
      "required": [
        "arguments",
        "id",
        "name"
      ],
      "properties": {
        "arguments": {
          "description": "JSON object encoded as a string, retained incrementally and losslessly across streams.",
          "type": "string"
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "ToolChoiceMode": {
      "type": "string",
      "enum": [
        "none",
        "auto",
        "required"
      ]
    },
    "ToolChoiceV1": {
      "anyOf": [
        {
          "$ref": "#/definitions/ToolChoiceMode"
        },
        {
          "type": "object",
          "required": [
            "name"
          ],
          "properties": {
            "name": {
              "type": "string"
            }
          }
        }
      ]
    },
    "ToolDefinitionV1": {
      "type": "object",
      "required": [
        "name",
        "parameters"
      ],
      "properties": {
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        },
        "parameters": true,
        "strict": {
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    }
  }
}
