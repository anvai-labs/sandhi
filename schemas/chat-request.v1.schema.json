{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ChatRequestV1",
  "type": "object",
  "required": [
    "messages",
    "model"
  ],
  "properties": {
    "extensions": {
      "type": "object",
      "additionalProperties": true
    },
    "max_output_tokens": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "minimum": 0.0
    },
    "messages": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ChatMessageV1"
      }
    },
    "metadata": {
      "default": {},
      "allOf": [
        {
          "$ref": "#/definitions/RequestMetadataV1"
        }
      ]
    },
    "model": {
      "type": "string"
    },
    "response_format": true,
    "schema_version": {
      "default": "1",
      "type": "string"
    },
    "seed": {
      "type": [
        "integer",
        "null"
      ],
      "format": "int64"
    },
    "stop": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "temperature": {
      "type": [
        "number",
        "null"
      ],
      "format": "double"
    },
    "tool_choice": {
      "anyOf": [
        {
          "$ref": "#/definitions/ToolChoiceV1"
        },
        {
          "type": "null"
        }
      ]
    },
    "tools": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ToolDefinitionV1"
      }
    }
  },
  "definitions": {
    "ChatMessageV1": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "content",
            "role"
          ],
          "properties": {
            "content": {
              "$ref": "#/definitions/MessageContent"
            },
            "name": {
              "type": [
                "string",
                "null"
              ]
            },
            "role": {
              "type": "string",
              "enum": [
                "developer"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "content",
            "role"
          ],
          "properties": {
            "content": {
              "$ref": "#/definitions/MessageContent"
            },
            "name": {
              "type": [
                "string",
                "null"
              ]
            },
            "role": {
              "type": "string",
              "enum": [
                "system"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "content",
            "role"
          ],
          "properties": {
            "content": {
              "$ref": "#/definitions/MessageContent"
            },
            "name": {
              "type": [
                "string",
                "null"
              ]
            },
            "role": {
              "type": "string",
              "enum": [
                "user"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "role"
          ],
          "properties": {
            "content": {
              "anyOf": [
                {
                  "$ref": "#/definitions/MessageContent"
                },
                {
                  "type": "null"
                }
              ]
            },
            "name": {
              "type": [
                "string",
                "null"
              ]
            },
            "refusal": {
              "type": [
                "string",
                "null"
              ]
            },
            "role": {
              "type": "string",
              "enum": [
                "assistant"
              ]
            },
            "tool_calls": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/ToolCallV1"
              }
            }
          }
        },
        {
          "type": "object",
          "required": [
            "content",
            "role",
            "tool_call_id"
          ],
          "properties": {
            "content": {
              "$ref": "#/definitions/MessageContent"
            },
            "role": {
              "type": "string",
              "enum": [
                "tool"
              ]
            },
            "tool_call_id": {
              "type": "string"
            }
          }
        },
        {
          "description": "Legacy Chat Completions function result; retained for lossless compatibility.",
          "type": "object",
          "required": [
            "content",
            "name",
            "role"
          ],
          "properties": {
            "content": {
              "$ref": "#/definitions/MessageContent"
            },
            "name": {
              "type": "string"
            },
            "role": {
              "type": "string",
              "enum": [
                "function"
              ]
            }
          }
        }
      ]
    },
    "ContentPart": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "text",
            "type"
          ],
          "properties": {
            "text": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "text"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "image_url",
            "type"
          ],
          "properties": {
            "detail": {
              "type": [
                "string",
