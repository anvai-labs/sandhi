{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProviderDescriptorV1",
  "type": "object",
  "required": [
    "base_url",
    "endpoint_family",
    "slug"
  ],
  "properties": {
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "base_url": {
      "type": "string"
    },
    "capabilities": {
      "default": {
        "audio_input": false,
        "file_input": false,
        "parallel_tool_calls": false,
        "prompt_cache_usage": false,
        "reasoning": false,
        "streaming": false,
        "structured_output": false,
        "tools": false,
        "vision": false
      },
      "allOf": [
        {
          "$ref": "#/definitions/ProviderCapabilitiesV1"
        }
      ]
    },
    "endpoint_family": {
