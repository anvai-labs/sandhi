    "schema_version": {
      "default": "1",
      "type": "string"
    },
    "slug": {
      "type": "string"
    }
  },
  "definitions": {
    "EndpointFamilyV1": {
      "type": "string",
      "enum": [
        "openai_chat_completions",
        "openai_responses",
        "anthropic_messages",
        "gemini_generate_content",
        "cohere_chat",
        "ollama_chat",
        "bedrock_converse",
        "host_callback"
      ]
    },
    "ModelDescriptorV1": {
      "type": "object",
      "required": [
        "id"
      ],
      "properties": {
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "capabilities": {
          "default": {
            "audio_input": false,
            "file_input": false,
            "parallel_tool_calls": false,
            "prompt_cache_usage": false,
            "reasoning": false,
            "streaming": false,
            "structured_output": false,
            "tools": false,
            "vision": false
          },
          "allOf": [
            {
              "$ref": "#/definitions/ProviderCapabilitiesV1"
            }
          ]
        },
        "default_temperature": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "endpoint_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        },
        "id": {
          "type": "string"
        },
        "max_input_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "max_output_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "ProviderCapabilitiesV1": {
      "type": "object",
      "properties": {
        "audio_input": {
          "default": false,
