        },
        "prompt_cache_usage": {
          "default": false,
          "type": "boolean"
        },
        "reasoning": {
          "default": false,
          "type": "boolean"
        },
        "streaming": {
          "default": false,
          "type": "boolean"
        },
        "structured_output": {
          "default": false,
          "type": "boolean"
        },
        "tools": {
          "default": false,
          "type": "boolean"
        },
        "vision": {
          "default": false,
          "type": "boolean"
        }
