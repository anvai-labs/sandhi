{
  "name": "@anvai-labs/sandhi",
  "version": "0.1.0",
  "description": "Sandhi — the metering layer for AI agents (Node binding): in-process virtual keys, budgets, and neutral usage-event metering.",
  "license": "Apache-2.0",
  "repository": "https://github.com/anvai-labs/sandhi",
  "keywords": ["llm", "gateway", "usage", "metering", "attribution", "ai"],
  "main": "sandhi.js",
  "types": "sandhi.d.ts",
  "napi": {
    "name": "sandhi",
    "triples": {
      "defaults": true,
      "additional": ["aarch64-apple-darwin", "aarch64-unknown-linux-gnu"]
    }
  },
  "engines": {
    "node": ">= 16"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "node --test __test__/gateway.test.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4"
  }
}
